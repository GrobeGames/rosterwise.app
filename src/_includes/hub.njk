{% extends "base.njk" %}

{% block content %}
<div class="content-layout">

  {% include "sidebar.njk" %}

<div class="hub-page">

  {% if breadcrumbs %}
  <nav class="breadcrumbs" aria-label="Breadcrumb">
    <ol>
      {% for crumb in breadcrumbs %}
      <li>
        {% if crumb.url %}<a href="{{ crumb.url }}">{{ crumb.text }}</a>
        {% else %}<span aria-current="page">{{ crumb.text }}</span>{% endif %}
      </li>
      {% endfor %}
    </ol>
  </nav>
  {% endif %}

  <header class="hub-header">
    <h1>{{ title }}</h1>
  </header>

  <div class="hub-intro">
    {{ content | safe }}
  </div>

  {% if children %}
  <section class="hub-children">
    {% for child in children %}
    <div class="hub-card{% if child.status == 'coming-soon' %} hub-card--coming{% endif %}">
      {% if child.status == 'coming-soon' %}
      <span class="hub-card-badge">Coming Soon</span>
      {% endif %}
      <h3>
        {% if child.status != 'coming-soon' %}
        <a href="{{ child.url }}">{{ child.title }}</a>
        {% else %}
        {{ child.title }}
        {% endif %}
      </h3>
      {% if child.summary %}<p>{{ child.summary }}</p>{% endif %}
    </div>
    {% endfor %}
  </section>
  {% endif %}

  <section class="hub-cta">
    <h2>Find your athlete&rsquo;s best-fit programs</h2>
    <p>RosterWise&trade; analyzes every roster at every NCAA and NAIA program &mdash; position depth, recruiting patterns, international composition, and more &mdash; so families can target the right schools with confidence.</p>
    <a href="/#download" class="hub-cta-btn">Get RosterWise&trade; &rarr;</a>
  </section>

</div>
</div><!-- .content-layout -->
{% endblock %}
