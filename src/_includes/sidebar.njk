<script>
  // Sidebar toggle for mobile
  const sidebarToggle = document.getElementById('sidebarToggle');
  const sidebarNav = document.getElementById('sidebarNav');
  if (sidebarToggle && sidebarNav) {
    sidebarToggle.addEventListener('click', () => {
      sidebarNav.classList.toggle('open');
      sidebarToggle.classList.toggle('open');
    });
  }

  // Expand/collapse all sidebar groups
  document.querySelectorAll('.sidebar-group-toggle').forEach(btn => {
    btn.addEventListener('click', () => {
      const group = btn.closest('.sidebar-group');
      const isExpanded = group.classList.contains('expanded');
      group.classList.toggle('expanded');
      btn.setAttribute('aria-expanded', !isExpanded);
    });
  });

  // Highlight current page and auto-expand its parent sections
  const currentPath = window.location.pathname;
  document.querySelectorAll('.sidebar-nav a').forEach(link => {
    if (link.getAttribute('href') === currentPath) {
      link.classList.add('active');
      // Walk up and expand all parent groups
      let el = link.closest('.sidebar-group');
      while (el) {
        el.classList.add('expanded');
        const toggle = el.querySelector(':scope > .sidebar-group-toggle');
        if (toggle) toggle.setAttribute('aria-expanded', 'true');
        el = el.parentElement ? el.parentElement.closest('.sidebar-group') : null;
      }
    }
  });
</script>
