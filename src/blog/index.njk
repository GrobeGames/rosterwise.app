---
layout: base.njk
title: "Blog | RosterWise™"
description: "Recruiting insights, roster analysis, and practical advice for college sports recruiting families. From the team at RosterWise."
breadcrumbs:
  - text: Home
    url: /
  - text: Blog
---

{% block content %}
<div class="content-layout">

  {% include "sidebar.njk" %}

<article class="content-page">

  <nav class="breadcrumbs" aria-label="Breadcrumb">
    <ol>
      {% for crumb in breadcrumbs %}
      <li>
        {% if crumb.url %}<a href="{{ crumb.url }}">{{ crumb.text }}</a>
        {% else %}<span aria-current="page">{{ crumb.text }}</span>{% endif %}
      </li>
      {% endfor %}
    </ol>
  </nav>

  <header class="content-header">
    <h1>RosterWise Blog</h1>
    <p class="content-meta">Recruiting insights, roster analysis, and practical advice for families navigating college sports.</p>
  </header>

  <div class="content-body">

    <p class="blog-feed-link"><a href="/blog/feed.xml">RSS Feed</a></p>

    {% set blogPosts = collections.blog | reverse %}
    {% if blogPosts.length %}
    <div class="blog-list">
      {% for post in blogPosts %}
      <article class="blog-card">
        <h2><a href="{{ post.url }}">{{ post.data.title }}</a></h2>
        <p class="content-meta">
          {% if post.data.author %}By {{ post.data.author }} &middot; {% endif %}
          <time datetime="{{ post.date | dateISO }}">{{ post.date | dateDisplay }}</time>
          &middot; {{ post.content | readingTime }}
        </p>
        {% if post.data.excerpt %}
        <p>{{ post.data.excerpt }}</p>
        {% endif %}
        <a href="{{ post.url }}" class="blog-read-more">Read more &rarr;</a>
      </article>
      {% endfor %}
    </div>
    {% else %}
    <p>No posts yet. Check back soon.</p>
    {% endif %}

  </div>

  <section class="content-cta">
    <h2>Stop guessing. Start seeing.</h2>
    <p>RosterWise&trade; analyzes every D1, D2, D3, and NAIA program &mdash; 2,200+ men&rsquo;s and women&rsquo;s soccer rosters. Position depth, class-year gaps, international composition, and personalized My RosterFit&trade; scoring.</p>
    <p class="content-cta-price">One payment of $40. No subscriptions. No ads. Available beginning May 2026.</p>
    <a href="/#download" class="content-cta-btn">Get RosterWise&trade; &rarr;</a>
  </section>

  <div class="content-byline">
    <p>RosterWise &mdash; Grobe Games LLC</p>
  </div>

</article>
</div>
{% endblock %}
